<body>
    <div class="container">
        <header>
            <h1>💊 Antimicrobial Prophylaxis Guide</h1>
            <p class="header-subtitle">Comprehensive reference for antibacterial, antifungal, antiviral, and PJP prophylaxis by disease and regimen</p>
        </header>
        
        <nav class="quick-nav">
            <button class="nav-btn" onclick="scrollToSection('overview')">Overview</button>
            <button class="nav-btn" onclick="scrollToSection('by-disease')">By Disease</button>
            <button class="nav-btn" onclick="scrollToSection('medications')">Medications</button>
